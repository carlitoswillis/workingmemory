# Copy to .env.local (gitignored). Local single-user use needs NONE of these —
# `npm run dev` with no env vars is the normal local setup.

# Where SQLite files live (default ./data). The hosted deploy points this at a
# mounted volume, e.g. /data.
#DATA_DIR=./data

# Hosted portfolio demo: every visitor gets an ephemeral seeded board.
# (`npm run dev:demo` sets this for you locally.)
#DEMO_MODE=1

# Single-owner auth on the hosted instance (only meaningful with DEMO_MODE=1):
# a valid session for this secret routes to the real owner board at
# DATA_DIR/owner/wm.db instead of a demo board, and authenticates /api/export.
# Use a long random value: openssl rand -base64 32
#OWNER_SECRET=
